<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <h1>Hello</h1>
    <ul>
        <% for(let listings of allListings){ %>
            <li>
                <a href="/listing/<%= listings._id %>">
                <%= listings.title %>
                </a>
            </li> 
    <% } %>
    </ul>
    <form action="/listing/new">
        <button type="submit">Create new Listing</button>
    </form>
</body>
</html>


    
